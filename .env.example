APP_NAME="Solar Soluções Solis"
APP_ENV=development
APP_DEBUG=true
API_BASE_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_DB=solis
POSTGRES_USER=solis
POSTGRES_PASSWORD=solis_dev_password
DATABASE_URL=postgresql+psycopg://solis:solis_dev_password@db:5432/solis

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIELD_ENCRYPTION_KEY=change-this-32-byte-minimum-secret

OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
ENABLE_GENERATIVE_AI=false

WHATSAPP_PROVIDER=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_API_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=solis_verify_token_dev
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v20.0

ATTACHMENT_STORAGE=local
ATTACHMENT_BASE_URL=http://localhost:8000/uploads
CHAT_ATTACHMENT_STORAGE_PATH=storage/chat_attachments
PROPOSAL_STORAGE_PATH=storage/proposals
PROPOSAL_PUBLIC_BASE_URL=

ENERGY_BILL_EXTRACTION_ENABLED=true
ENERGY_BILL_OCR_ENABLED=false
ENERGY_BILL_OCR_PROVIDER=disabled
ENERGY_BILL_ALLOW_EXTERNAL_AI=false
ENERGY_BILL_MAX_FILE_SIZE_MB=10
ENERGY_BILL_STORE_RAW_TEXT=false
ENERGY_BILL_MIN_CONFIDENCE_AUTO_APPLY=0.85
ENERGY_BILL_STORAGE_PATH=storage/energy_bills

COMPANY_NAME="Solar Solucoes"
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_WEBSITE=https://solarsolucoes.com.br
COMPANY_ADDRESS=
COMPANY_LOGO_PATH=
COMPANY_PRIMARY_COLOR=#FFCC33
COMPANY_SECONDARY_COLOR=#0B1F33

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="Solar Solucoes"
SMTP_USE_TLS=true

RATE_LIMIT_PER_MINUTE=80
LOG_LEVEL=INFO
